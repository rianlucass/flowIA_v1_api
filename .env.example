# Application
SPRING_APPLICATION_NAME=flowia-api
SERVER_PORT=8080

# Supabase Postgres
# Copy values from Supabase > Project Settings > Database
# IMPORTANT: keep sslmode=require for Supabase
DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=<your-supabase-db-password>

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_OPEN_IN_VIEW=false
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true
JPA_TIMEZONE=UTC

# Hikari pool
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000

# SQL init (never | embedded | always)
SQL_INIT_MODE=never

# Microservice OCR url
OCR_SERVICE_URL=localhost:5000/ocr